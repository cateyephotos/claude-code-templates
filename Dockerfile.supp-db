FROM nginx:alpine

# Install inotify-tools for file watching (auto-refresh support)
RUN apk add --no-cache inotify-tools

# Copy nginx config for the static supplement database site
COPY nginx-supp-db.conf /etc/nginx/conf.d/default.conf

# Copy the static site files
COPY supp-db-site/ /usr/share/nginx/html/

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]
