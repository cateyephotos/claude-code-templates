FROM nginx:alpine

# Install inotify-tools for file watching (auto-refresh support)
# and curl for healthcheck
RUN apk add --no-cache inotify-tools curl

# Copy nginx config for the static supplement database site
COPY nginx-supp-db.conf /etc/nginx/conf.d/default.conf

# Copy the docker entrypoint script (env var substitution)
COPY supp-db-site/docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

# Copy the static site files
COPY supp-db-site/ /usr/share/nginx/html/

EXPOSE 8080

ENTRYPOINT ["/docker-entrypoint.sh"]
