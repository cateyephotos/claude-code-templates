# SupplementDB Environment Variables
# Copy this file to .env and fill in the values

# ── Clerk Authentication ───────────────────────────────────────
# Get these from https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# ── Convex Backend ─────────────────────────────────────────────
# Get these from https://dashboard.convex.dev
CONVEX_URL=https://robust-frog-754.convex.cloud
CONVEX_DEPLOY_KEY=prod:xxxxx

# ── PostHog Analytics ──────────────────────────────────────────
# PostHog uses TWO different keys — do not confuse them.
#
# 1. POSTHOG_KEY (phc_...) — client-side project API key, used by
#    posthog-js in the browser to capture events. Safe to ship to
#    the client via the <meta> tag in HTML pages. Read from PostHog
#    → Project Settings → Project API Key.
#
# 2. POSTHOG_API_KEY (phx_...) — server-side personal API key, used
#    by Convex actions (convex/posthog.ts) to query the PostHog REST
#    API for admin dashboard analytics. MUST NOT be shipped to the
#    client. Read from PostHog → Settings → Personal API Keys, with
#    scopes: read:project, read:insight, read:event_definition.
#
# Using the wrong key type causes silent failures — a phc_ key
# returns 401 from the REST API, and the Convex action catches the
# error and returns an empty array, so the admin dashboard shows
# "no data" instead of a configuration error. See SUPP-119.
POSTHOG_KEY=phc_xxxxx                     # client capture (browser)
POSTHOG_API_KEY=phx_xxxxx                 # server read (Convex)
POSTHOG_PROJECT_ID=12345
POSTHOG_HOST=https://us.i.posthog.com

# ── Stripe Payments ──────────────────────────────────────────
# Set these in Convex Dashboard → Settings → Environment Variables
# (NOT in Docker .env — Convex actions read these server-side)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_MONTHLY_PRICE_ID=price_xxxxx
STRIPE_ANNUAL_PRICE_ID=price_xxxxx

# ── Resend Email ──────────────────────────────────────────────
# Set in Convex Dashboard → Settings → Environment Variables
# (NOT in Docker .env — Convex actions read this server-side)
RESEND_API_KEY=re_xxxxx

# ── Site URL ─────────────────────────────────────────────────
# Used by Stripe checkout & newsletter confirmation/unsubscribe URLs
# Set in Convex Dashboard environment variables
SITE_URL=http://localhost:8080

# ── Email Sequence System ───────────────────────────────────────
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret
