# SupplementDB Environment Variables
# Copy this file to .env and fill in the values

# ── Clerk Authentication ───────────────────────────────────────
# Get these from https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# ── Convex Backend ─────────────────────────────────────────────
# Get these from https://dashboard.convex.dev
CONVEX_URL=https://robust-frog-754.convex.cloud
CONVEX_DEPLOY_KEY=prod:xxxxx

# ── PostHog Analytics ──────────────────────────────────────────
# Get these from https://app.posthog.com/project/settings
POSTHOG_KEY=phc_xxxxx
POSTHOG_PROJECT_ID=12345
POSTHOG_HOST=https://us.i.posthog.com

