# SupplementDB Environment Variables
# Copy this file to .env and fill in the values

# ── Clerk Authentication ───────────────────────────────────────
# Get these from https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# ── Convex Backend ─────────────────────────────────────────────
# Get these from https://dashboard.convex.dev
CONVEX_URL=https://robust-frog-754.convex.cloud
CONVEX_DEPLOY_KEY=prod:xxxxx

# ── PostHog Analytics ──────────────────────────────────────────
# Get these from https://app.posthog.com/project/settings
POSTHOG_KEY=phc_xxxxx
POSTHOG_PROJECT_ID=12345
POSTHOG_HOST=https://us.i.posthog.com

# ── Stripe Payments ──────────────────────────────────────────
# Set these in Convex Dashboard → Settings → Environment Variables
# (NOT in Docker .env — Convex actions read these server-side)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_MONTHLY_PRICE_ID=price_xxxxx
STRIPE_ANNUAL_PRICE_ID=price_xxxxx

# ── Resend Email ──────────────────────────────────────────────
# Set in Convex Dashboard → Settings → Environment Variables
# (NOT in Docker .env — Convex actions read this server-side)
RESEND_API_KEY=re_xxxxx

# ── Site URL ─────────────────────────────────────────────────
# Used by Stripe checkout & newsletter confirmation/unsubscribe URLs
# Set in Convex Dashboard environment variables
SITE_URL=http://localhost:8080

# ── Email Sequence System ───────────────────────────────────────
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret
