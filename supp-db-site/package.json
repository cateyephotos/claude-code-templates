{
  "name": "supp-db-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "npx playwright test",
    "test:auth": "npx playwright test tests/auth-flow.spec.js",
    "test:rbac": "npx playwright test tests/rbac.spec.js",
    "test:gate": "npx playwright test tests/content-gate.spec.js",
    "test:dashboard": "npx playwright test tests/admin-dashboard.spec.js",
    "test:pdf": "npx playwright test tests/pdf-generator-api.spec.js",
    "test:guide-success": "npx playwright test tests/guide-success.spec.js",
    "test:idempotency": "node tests/stripe-webhook-idempotency.js",
    "test:mobile": "npx playwright test tests/stripe-checkout.spec.js --grep @mobile",
    "test:bro46": "npm run test:pdf && npm run test:guide-success",
    "convex:dev": "npx convex dev",
    "convex:deploy": "npx convex deploy",
    "deploy:convex:prod": "node scripts/convex-deploy-prod.js",
    "inject-auth": "node scripts/inject-auth.js",
    "generate:supplements": "node seed.js --out supplements/",
    "generate:guides": "node scripts/generate-guide-pages.js",
    "generate:compare": "node scripts/generate-compare-pages.js",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "submit:sitemap:prod": "npx convex run --prod gsc:submitSitemap",
    "sitemap:regen-and-submit": "npm run generate:sitemap && npm run submit:sitemap:prod",
    "evidence:check": "node scripts/pubmed-evidence-monitor.js",
    "audit:fda": "node scripts/audit-fda-claims.js",
    "heal": "node healing-engine/run-healing.js",
    "heal:dry-run": "node healing-engine/run-healing.js --dry-run --skip-browser --skip-links",
    "heal:full": "node healing-engine/run-healing.js --json",
    "heal:data": "node healing-engine/run-healing.js --stage data-validation --json",
    "heal:citations": "node healing-engine/run-healing.js --stage citation-healing --json",
    "heal:site": "node healing-engine/run-healing.js --stage site-check --json",
    "heal:quality": "node healing-engine/run-healing.js --stage content-quality --json",
    "test:healing": "npx playwright test tests/healing-engine/",
    "heal:flag": "node healing-engine/scripts/flag-evidence-quality.js",
    "heal:remediate": "node healing-engine/scripts/remediate-supplement.js",
    "heal:regenerate": "node healing-engine/scripts/regenerate-and-diff.js",
    "journal": "cd .. && node supp-db-site/sprint-journal/generate.js --since-last --config supp-db-site/sprint-journal/config.json --output supp-db-site/sprint-journal",
    "journal:full": "cd .. && node supp-db-site/sprint-journal/generate.js --config supp-db-site/sprint-journal/config.json --output supp-db-site/sprint-journal"
  },
  "devDependencies": {
    "cheerio": "^1.2.0",
    "convex": "^1.17.0",
    "playwright": "^1.55.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "resend": "^4.0.0",
    "sharp": "^0.34.5",
    "stripe": "^17.7.0"
  },
  "description": "A comprehensive interactive website featuring evidence-based supplements with standardized citation display, backed by 471+ research papers and systematic reviews. **Now achieving 95%+ reliability with uniform citation formatting across all supplements.**",
  "main": "analyze-expansion-opportunities.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
